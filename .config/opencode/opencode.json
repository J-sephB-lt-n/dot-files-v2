{
  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "sudo *": "deny"
    }
  },

  "provider": {
    "gaiss": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "gaiss",
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}",
        "apiKey": "{env:OPENAI_API_KEY}",
        "includeUsage": true
      },
      "models": {
        "bedrock.anthropic.claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 Thinking",
          "options": {
            "thinking": {
              "type": "enabled",
              "budget_tokens": 12000
            }
          },
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "cost": {
            "input": 3,
            "output": 15
          }
        },
        "bedrock.anthropic.claude-opus-4-6": {
          "name": "Claude Opus 4.6 Thinking",
          "options": {
            "thinking": {
              "type": "enabled",
              "budget_tokens": 12000
            }
          },
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "cost": {
            "input": 5.5,
            "output": 27.5
          }
        },
        "openai.eu.gpt-5.4-mini-2026-03-17": {
          "name": "GPT 5-4 mini",
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "cost": {
            "input": 0.75,
            "output": 4.5
          }
        },
        "bedrock.anthropic.claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5"
        },
        "openai.gpt-5.5": {
          "name": "GPT 5.5"
        },
        "vertex_ai.anthropic.claude-opus-4": {
          "name": "Claude Opus 4"
        },
        "vertex_ai.gemini-3-pro-preview": {
          "name": "Gemini 3 Pro"
        }
      }
    }
  },
  "model": "gaiss/bedrock.anthropic.claude-sonnet-4-6"
}
